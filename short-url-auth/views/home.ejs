<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body{
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>url page</h1>
    <% if (locals.id) { %>
        <p>Sushant has ids</p>
    <% } %>
    
    <div>
        <form action="/url" method="post">
            <label for="">Enter your Original URL</label>
            <input type="text" placeholder="https://example.com" name="originalUrl">
            <button type="submit">Generate</button>
        </form>
    </div>


    <% if (locals.url) { %>
    <table>
        <thead>
            <tr>
                <th>S.No.</th>
                <th>ShortId</th>
                <th>Redirect URL</th>
                <th>Clicks</th>
            </tr>
        </thead>
        <tbody>
            <% url.forEach((url,index) => { %>
                <tr>
                    <td><%= index+1 %></td>
                    <td><%= url.shortId %></td>
                    <td><%= url.redirectUrl %></td>
                    <td><%= url.visitHistory.length %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <% } %>
</body>
</html>